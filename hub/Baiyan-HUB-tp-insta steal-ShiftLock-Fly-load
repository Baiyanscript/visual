local function savePos()
    local char = Player.Character
    if char then
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then
            savedPosition = hrp.CFrame
            StarterGui:SetCore("SendNotification", {Title = "Save Pos", Text = "Position saved!", Duration = 3})
        end
    end
end

local function tpToSaved()
    local char = Player.Character
    if char and savedPosition then
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then
            hrp.CFrame = savedPosition
            StarterGui:SetCore("SendNotification", {Title = "Teleport", Text = "Back to saved spot!", Duration = 3})
        end
    else
        StarterGui:SetCore("SendNotification", {Title = "Teleport", Text = "No position saved yet!", Duration = 3})
    end
end

